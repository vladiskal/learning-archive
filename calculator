num1 = int(input("Ingrese un número: "))
num2 = int(input("Ingrese otro número: "))

print("¿Qué quiere hacer con estos datos?")
print("1. Suma")
print("2. Resta")
print("3. Multiplicación")
print("4. División")

opcion = input("Seleccione una opción: ")

if opcion == "1":
    print("La suma de sus números es:", num1 + num2)

elif opcion == "2":
    print("La resta de sus números es:", num1 - num2)

elif opcion == "3":
    print("La multiplicación de sus números es:", num1 * num2)

elif opcion == "4":
    if num2 == 0:
        print("No se puede dividir por cero")
    else:
        print("La división de sus números es:", num1 / num2)

else:
    print("Operación Inválida")
